# ── Database ──────────────────────────────────────────────────────────────────
# Get this from Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash). Multiple URLs: comma-separated
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
